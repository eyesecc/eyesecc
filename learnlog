        'Take any exploit you\'ve built this year. Write a professional vulnerability report: title, severity (CVSS), description, PoC, impact, remediation',
        'Write it so a developer who doesn\'t know pentesting can reproduce and fix it',
        'This is the skill that turns technical knowledge into professional output',
        'Re-read your Phase 1 methodology doc — how has your thinking changed? Update it completely',
      ]},
      {n:52, title:'Final validation — solve a Hard machine, no help', tasks:[
        'Pick a retired Hard HTB machine you\'ve never looked at. Solve it with no help, no hints',
        'The constraint: before running any tool, write down what you expect to find and why',
        'Compare expectation to reality at every step — where did your model fail?',
        'You\'re done when the gap between your predictions and the machine\'s behavior is small. That\'s the logic you built',
      ]},
    ]
  }
];

function build(){
  const container=document.getElementById('phases');
  phases.forEach(ph=>{
    const wrap=document.createElement('div');
    wrap.style.marginBottom='8px';
    const hdr=document.createElement('div');
    hdr.className='phase-header';
    hdr.innerHTML=`<div class="dot ${ph.color}-dot"></div><div><div class="phase-title">${ph.title}</div><div class="phase-sub">${ph.sub}</div></div><span class="badge ${ph.color}-badge">${ph.badge}</span><span class="chevron" id="chev-${ph.id}">▾</span>`;
    const wk=document.createElement('div');
    wk.className='weeks';
    wk.id='weeks-'+ph.id;
    ph.weeks.forEach(w=>{
      const wd=document.createElement('div');
      wd.className='week';
      wd.innerHTML=`<div class="week-label">Week ${w.n}</div><div class="week-title">${w.title}</div><div class="week-body" id="wb-${ph.id}-${w.n}"><ul class="week-tasks">${w.tasks.map(t=>`<li>${t}</li>`).join('')}</ul></div>`;
      wd.onclick=(e)=>{e.stopPropagation();const b=document.getElementById(`wb-${ph.id}-${w.n}`);b.classList.toggle('open');};
      wk.appendChild(wd);
    });
    hdr.onclick=()=>{
      wk.classList.toggle('open');
      document.getElementById('chev-'+ph.id).classList.toggle('open');
    };
    wrap.appendChild(hdr);
    wrap.appendChild(wk);
    container.appendChild(wrap);
  });
}
build();
</script>
